# ──────────────────────────────────────────────────────────────────────────────
# Finance Tracker API — Environment Configuration
# Copy this file to .env and fill in your values.
# DO NOT commit .env to version control.
# ──────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default, no extra setup needed)
DATABASE_URL=sqlite:///./finance_tracker.db

# PostgreSQL example (swap DATABASE_URL if needed):
# DATABASE_URL=postgresql://user:password@localhost:5432/finance_tracker

# MySQL example:
# DATABASE_URL=mysql+pymysql://user:password@localhost:3306/finance_tracker

# ── JWT Authentication ─────────────────────────────────────────────────────────
# IMPORTANT: Change this to a long, random secret in production.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=super-secret-key-change-in-production-please
ALGORITHM=HS256

# Token expiry in minutes (default: 1440 = 24 hours)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Application ────────────────────────────────────────────────────────────────
PROJECT_NAME="Finance Tracker API"
VERSION=1.0.0
ENVIRONMENT=development

# ── CORS ───────────────────────────────────────────────────────────────────────
# Allow all origins in development. Restrict in production:
# CORS_ORIGINS=["https://yourdomain.com","https://app.yourdomain.com"]
CORS_ORIGINS=["*"]
